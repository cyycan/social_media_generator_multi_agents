# ── LLM Providers (only one is needed) ───────────────────────────────────────
# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Google AI (Gemini)
GOOGLE_API_KEY=AIza...

# ── Platform API Credentials (optional — needed for Live publishing) ──────────
# Twitter/X (v1.1)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# LinkedIn
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=urn:li:person:...

# ── App settings ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
